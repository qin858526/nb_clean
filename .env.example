# DeepSeek API Key（自行申请：https://platform.deepseek.com/）
DEEPSEEK_API_KEY = "sk-你的API Key"
# DeepSeek 模型名（可选，默认 deepseek-chat）
# DEEPSEEK_MODEL = "deepseek-chat"

# B站完整登录 Cookie（F12 → Application → Cookies → bilibili.com 复制全部）
# 需要包含 buvid3 / buvid4 / b_nut / _uuid / bili_ticket / SESSDATA / bili_jct 等
BILIBILI_COOKIE = "buvid3=xxx; buvid4=xxx; ..."
