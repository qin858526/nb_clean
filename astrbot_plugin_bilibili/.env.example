# DeepSeek API Key（https://platform.deepseek.com/ 申请）
DEEPSEEK_API_KEY=sk-你的APIKey
DEEPSEEK_MODEL=deepseek-v4-pro

# B站完整登录 Cookie（F12 → Application → Cookies → bilibili.com）
BILIBILI_COOKIE=buvid3=xxx; buvid4=xxx; SESSDATA=xxx; bili_jct=xxx; bili_ticket=xxx

# whisper.cpp 路径（如已在默认路径则无需修改）
# WHISPER_CLI=/root/whisper.cpp/build/bin/whisper-cli
# WHISPER_MODEL_PATH=/root/whisper.cpp/models/ggml-base.bin
# WHISPER_FAST_MODEL_PATH=/root/whisper.cpp/models/ggml-tiny.bin
